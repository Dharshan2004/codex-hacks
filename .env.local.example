# Shopee Live Producer — environment configuration
#
# Copy this file to `.env.local` and fill in the values from your hosted
# Supabase project (Project Settings -> API Keys). Restart `npm run dev`
# after editing.

# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# New-format publishable key (sb_publishable_...). The app also accepts a
# legacy anon JWT via NEXT_PUBLIC_SUPABASE_ANON_KEY if you prefer.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server-only — NEVER expose to the browser. New-format secret key
# (sb_secret_...). The app also accepts a legacy service_role JWT via
# SUPABASE_SERVICE_ROLE_KEY. Used by server routes for privileged writes.
SUPABASE_SECRET_KEY=sb_secret_xxx

# Optional: direct Postgres connection string (Project Settings -> Database).
# Only needed for `npm run db:push` to apply migrations + seed from the CLI.
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR-PROJECT-ref.supabase.co:5432/postgres
